      "wcagLevel": "A",
      "principle": "perceivable",
      "severity": "serious",
      "description": "Radio button groups for 'Gender' and 'Preferred pharmacy' are not programmatically grouped. Screen reader users cannot determine the question context for each option.",
      "fixSuggestion": "Wrap related radio buttons in a fieldset with a legend element, or use role='group' with aria-labelledby.",
