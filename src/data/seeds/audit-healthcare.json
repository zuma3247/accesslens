    {
      "id": "form-label",
      "ruleId": "form-label",
      "wcagCriterion": "1.3.1",
      "wcagCriterionName": "Info and Relationships",
      "wcagLevel": "A",
      "principle": "perceivable",
      "severity": "critical",
      "description": "Medical history form fields use placeholder text as labels. When users begin typing, the label disappears, making it difficult to verify which field is active.",
      "fixSuggestion": "Add visible labels above each input field using the label element with proper for/id association.",
      "helpUrl": "https://www.w3.org/WAI/WCAG22/Understanding/info-and-relationships.html",
      "codeSnippet": "<input type=\"text\" placeholder=\"Previous surgeries\">",
      "codeFixExample": "<label for=\"surgeries\">Previous surgeries</label><input id=\"surgeries\" type=\"text\">",
      "affectedCount": 6,
      "hasBeforeAfter": false
    },
    {
      "id": "color-contrast",
      "ruleId": "color-contrast",
      "wcagCriterion": "1.4.3",
      "wcagCriterionName": "Contrast (Minimum)",
      "wcagLevel": "AA",
      "principle": "perceivable",
      "severity": "serious",
      "description": "The 'Emergency Contact' heading uses light blue text (#66AADD) with 3.1:1 contrast. Users with low vision cannot distinguish this from the background.",
      "fixSuggestion": "Change heading color to #2277AA or darker to achieve 4.5:1 contrast ratio.",
      "helpUrl": "https://www.w3.org/WAI/WCAG22/Understanding/contrast-minimum.html",
      "codeSnippet": "<h3 style=\"color: #66AADD\">Emergency Contact</h3>",
      "codeFixExample": "<h3 style=\"color: #2277AA\">Emergency Contact</h3>",
      "affectedCount": 3,
      "hasBeforeAfter": true,
      "beforeAfterType": "contrast"
    },
    {
      "id": "session-timeout",
      "ruleId": "session-timeout",
      "wcagCriterion": "2.2.1",
      "wcagCriterionName": "Timing Adjustable",
      "wcagLevel": "A",
      "principle": "operable",
      "severity": "critical",
      "description": "The session expires after 15 minutes with no warning. Users may lose unsaved medical information. No option to extend session is provided.",
      "fixSuggestion": "Provide a warning before timeout (e.g., at 10 minutes) with option to extend. Allow users to request longer sessions.",
      "helpUrl": "https://www.w3.org/WAI/WCAG22/Understanding/timing-adjustable.html",
      "codeSnippet": "<meta http-equiv=\"refresh\" content=\"900;url=/timeout\">",
      "codeFixExample": "<div role=\"alert\" id=\"timeout-warning\">Session expires in 2 minutes. <button>Extend session</button></div>",
      "affectedCount": 1,
      "hasBeforeAfter": false
    },
    {
      "id": "error-identification",
      "ruleId": "error-identification",
      "wcagCriterion": "3.3.1",
      "wcagCriterionName": "Error Identification",
      "wcagLevel": "A",
      "principle": "understandable",
      "severity": "serious",
      "description": "When the insurance ID format is invalid, only the field border turns red. No text message explains the required format (XXX-XXXXXX-XX).",
      "fixSuggestion": "Add aria-invalid='true' and an associated error message describing the correct format.",
      "helpUrl": "https://www.w3.org/WAI/WCAG22/Understanding/error-identification.html",
      "codeSnippet": "<input class=\"field-error\" style=\"border-color: red\">",
      "codeFixExample": "<input aria-invalid=\"true\" aria-describedby=\"insurance-error\"><span id=\"insurance-error\">Format: XXX-XXXXXX-XX (e.g., ABC-123456-01)</span>",
      "affectedCount": 2,
      "hasBeforeAfter": false
    },
    {
