      "codeSnippet": "<div><input type=\"radio\" name=\"gender\" value=\"m\"> Male</div>",
      "codeFixExample": "<fieldset><legend>Gender</legend><div><input type=\"radio\" name=\"gender\" value=\"m\"> Male</div></fieldset>",
      "affectedCount": 4,
      "hasBeforeAfter": false
    },
