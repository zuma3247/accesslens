      "codeSnippet": "<span class=\"price\" style=\"color: #AAAAAA\">$49.99</span>",
      "codeFixExample": "<span class=\"price\" style=\"color: #595959\">$49.99</span>",
      "affectedCount": 12,
      "hasBeforeAfter": true,
      "beforeAfterType": "contrast"
    },
    {
      "id": "form-label",
